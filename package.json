    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "cheerio": "1.1.2",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "^4.1.10"
  }
